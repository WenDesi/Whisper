{
  "Llm": {
    "Endpoint": "https://YOUR-OPENAI-RESOURCE.openai.azure.com/openai/v1/",
    "ApiKey": "YOUR-OPENAI-KEY",
    "Model": "gpt-4o"
  },
  "AzureSpeech": {
    "Endpoint": "https://YOUR-SPEECH-RESOURCE.cognitiveservices.azure.com/",
    "SubscriptionKey": "YOUR-SPEECH-KEY",
    "Region": "japaneast",
    "Language": "zh-CN"
  },
  "VolcengineSpeech": {
    "ApiKey": "YOUR-API-KEY",
    "ResourceId": "volc.seedasr.sauc.duration"
  },
  "Hotkeys": {
    "PushToTalk": "RightAlt",
    "PasteTranscription": "Ctrl+Shift+V",
    "CorrectionHotkey": "RightShift"
  },
  "Audio": {
    "SampleRate": 16000,
    "Channels": 1,
    "BitsPerSample": 16,
    "DeviceId": ""
  },
  "Transcription": {
    "SpeechProvider": "Volcengine",
    "CleanupProvider": "OpenAI",
    "Language": "zh",
    "Prompt": "This audio contains Chinese speech with occasional English technical terms like Redis, Kubernetes, Docker, API, SDK, Azure, etc.",
    "LogFile": "transcription-history.log"
  },
  "Recording": {
    "SavePath": ""
  },
  "Pipeline": {
    "SttProvider": "AzureSpeech",
    "LlmProvider": "OpenAI",
    "Language": "zh",
    "AutoDetectLanguages": ["zh-CN", "en-US"],
    "HotWordsFile": "hotwords.json",
    "EnableTextCleanup": true,
    "HistorySessionGapMinutes": 10,
    "Audio": {
      "SampleRate": 16000,
      "Channels": 1,
      "BitsPerSample": 16
    }
  }
}
