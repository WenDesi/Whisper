<Window x:Class="WhisperDesk.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:WhisperDesk.ViewModels"
        mc:Ignorable="d"
        Title="WhisperDesk"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="520" Height="680"
        MinWidth="420" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <materialDesign:DialogHost Identifier="RootDialog">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <materialDesign:ColorZone Grid.Row="0" Mode="PrimaryMid" Padding="16">
                <DockPanel>
                    <materialDesign:PackIcon DockPanel.Dock="Left"
                                             Kind="Microphone"
                                             Width="28" Height="28"
                                             VerticalAlignment="Center"
                                             Margin="0,0,12,0" />
                    <!-- Settings button (right-aligned) -->
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                            ToolTip="Settings"
                            Command="{Binding OpenSettingsCommand}"
                            VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Cog" Width="22" Height="22" />
                    </Button>
                    <StackPanel>
                        <TextBlock Text="WhisperDesk"
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}" />
                        <TextBlock Text="Voice to text, powered by Azure OpenAI"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Opacity="0.7" />
                    </StackPanel>
                </DockPanel>
            </materialDesign:ColorZone>

            <!-- Status Bar -->
            <materialDesign:Card Grid.Row="1" Margin="16,12,16,0"
                                 UniformCornerRadius="12"
                                 Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Status indicator dot -->
                    <Ellipse Grid.Column="0"
                             Width="12" Height="12"
                             Margin="0,0,12,0"
                             VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#4CAF50" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                        <Setter Property="Fill" Value="#F44336" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <!-- Status text -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding StatusText}"
                               Style="{StaticResource MaterialDesignBody1TextBlock}"
                               VerticalAlignment="Center" />

                    <!-- Audio level meter -->
                    <ProgressBar Grid.Column="2"
                                 Width="80" Height="8"
                                 Value="{Binding AudioLevel}"
                                 Maximum="1.0"
                                 VerticalAlignment="Center"
                                 Visibility="{Binding IsRecording, Converter={StaticResource BoolToVis}}" />
                </Grid>
            </materialDesign:Card>

            <!-- Main Content - Transcription Display -->
            <Grid Grid.Row="2" Margin="16,12,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Cleaned text (primary) -->
                <materialDesign:Card Grid.Row="0" UniformCornerRadius="12" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="16,12,8,0">
                            <materialDesign:PackIcon Kind="TextBoxCheck"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,8,0"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}" />
                            <TextBlock Text="Cleaned Text"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       VerticalAlignment="Center" />
                            <StackPanel DockPanel.Dock="Right"
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal">
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="Copy to clipboard"
                                        Command="{Binding CopyToClipboardCommand}">
                                    <materialDesign:PackIcon Kind="ContentCopy" />
                                </Button>
                            </StackPanel>
                        </DockPanel>
                        <TextBox Grid.Row="1"
                                 Text="{Binding CleanedText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="16,4,16,12"
                                 BorderThickness="0"
                                 FontSize="15" />
                    </Grid>
                </materialDesign:Card>

                <GridSplitter Grid.Row="1" Height="8"
                              HorizontalAlignment="Stretch"
                              Background="Transparent" />

                <!-- Raw text (secondary) -->
                <materialDesign:Card Grid.Row="2" UniformCornerRadius="12" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="16,12,16,0">
                            <materialDesign:PackIcon Kind="TextBoxOutline"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,8,0"
                                                     Opacity="0.5" />
                            <TextBlock Text="Raw Transcription"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Opacity="0.6"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                        <TextBox Grid.Row="1"
                                 Text="{Binding RawText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="16,4,16,12"
                                 BorderThickness="0"
                                 Opacity="0.7"
                                 FontSize="13" />
                    </Grid>
                </materialDesign:Card>
            </Grid>

            <!-- Error Banner -->
            <materialDesign:Card Grid.Row="3"
                                 Margin="16,12,16,0"
                                 UniformCornerRadius="8"
                                 Background="#F44336"
                                 Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <DockPanel Margin="12,8">
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                            Foreground="White"
                            Command="{Binding DismissErrorCommand}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                    <TextBlock Text="{Binding LastError}"
                               Foreground="White"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </DockPanel>
            </materialDesign:Card>

            <!-- Bottom Controls -->
            <materialDesign:Card Grid.Row="4"
                                 Margin="16,12,16,16"
                                 UniformCornerRadius="12"
                                 Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Hotkey hints -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PushToTalkHint}"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}" Opacity="0.6" />
                        <TextBlock Text="{Binding PasteHint}"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}" Opacity="0.6" />
                    </StackPanel>

                    <!-- Record button -->
                    <Button Grid.Column="1"
                            Width="56" Height="56"
                            Command="{Binding ToggleRecordingCommand}"
                            ToolTip="Click to toggle recording">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFloatingActionButton}">
                                <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                        <Setter Property="Background" Value="#F44336" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <materialDesign:PackIcon Width="28" Height="28">
                            <materialDesign:PackIcon.Style>
                                <Style TargetType="materialDesign:PackIcon">
                                    <Setter Property="Kind" Value="Microphone" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                            <Setter Property="Kind" Value="Stop" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialDesign:PackIcon.Style>
                        </materialDesign:PackIcon>
                    </Button>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </materialDesign:DialogHost>
</Window>
