<UserControl x:Class="WhisperDesk.Views.EvalDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             MinWidth="480" MaxWidth="600"
             Margin="16">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <StackPanel>
        <!-- Header -->
        <DockPanel Margin="0,0,0,16">
            <materialDesign:PackIcon Kind="ClipboardEdit"
                                     Width="28" Height="28"
                                     VerticalAlignment="Center"
                                     Margin="0,0,12,0"
                                     Foreground="{DynamicResource PrimaryHueMidBrush}" />
            <StackPanel>
                <TextBlock Text="Evaluate Transcription"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}" />
                <TextBlock Text="Review, correct, and save with audio"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Opacity="0.6" />
            </StackPanel>
        </DockPanel>

        <!-- Audio Playback -->
        <materialDesign:Card UniformCornerRadius="8" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Play/Stop button -->
                <Button Grid.Column="0"
                        Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding TogglePlaybackCommand}"
                        ToolTip="Play / Stop audio"
                        Margin="0,0,8,0">
                    <materialDesign:PackIcon Width="24" Height="24">
                        <materialDesign:PackIcon.Style>
                            <Style TargetType="materialDesign:PackIcon">
                                <Setter Property="Kind" Value="Play" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                        <Setter Property="Kind" Value="Stop" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </materialDesign:PackIcon.Style>
                    </materialDesign:PackIcon>
                </Button>

                <!-- Progress bar -->
                <ProgressBar Grid.Column="1"
                             Value="{Binding PlaybackPosition}"
                             Maximum="{Binding PlaybackDuration}"
                             Height="6"
                             VerticalAlignment="Center" />

                <!-- Time display -->
                <TextBlock Grid.Column="2"
                           Text="{Binding PlaybackTimeText}"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           Opacity="0.7" />
            </Grid>
        </materialDesign:Card>

        <!-- Raw Text (read-only reference) -->
        <TextBlock Text="Raw Transcription (reference)"
                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                   Opacity="0.6"
                   Margin="0,0,0,4" />
        <TextBox Text="{Binding RawText, Mode=OneWay}"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 MaxHeight="100"
                 VerticalScrollBarVisibility="Auto"
                 Opacity="0.6"
                 FontSize="13"
                 Margin="0,0,0,16"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />

        <!-- Corrected Text (editable) -->
        <TextBlock Text="Corrected Text"
                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                   Foreground="{DynamicResource PrimaryHueMidBrush}"
                   Margin="0,0,0,4" />
        <TextBox Text="{Binding CorrectedText, UpdateSourceTrigger=PropertyChanged}"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 MinHeight="80"
                 MaxHeight="200"
                 VerticalScrollBarVisibility="Auto"
                 FontSize="14"
                 Margin="0,0,0,16"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />

        <!-- Success message -->
        <materialDesign:Card UniformCornerRadius="8"
                             Padding="12"
                             Margin="0,0,0,12"
                             Background="#388E3C"
                             Visibility="{Binding IsSaved, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <materialDesign:PackIcon Kind="CheckCircle"
                                         VerticalAlignment="Center"
                                         Foreground="White"
                                         Margin="0,0,8,0" />
                <TextBlock Foreground="White"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center">
                    <Run Text="Saved to: " />
                    <Run Text="{Binding SavedFilePath, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
            </DockPanel>
        </materialDesign:Card>

        <!-- Buttons -->
        <DockPanel Margin="0,4,0,0">
            <Button DockPanel.Dock="Right"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Content="CLOSE"
                    IsDefault="False"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="false"
                    Margin="8,0,0,0" />
            <Button DockPanel.Dock="Right"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Content="SAVE EVAL"
                    Command="{Binding SaveEvalCommand}"
                    IsEnabled="{Binding CanSave}" />
            <StackPanel /> <!-- Spacer -->
        </DockPanel>
    </StackPanel>
</UserControl>
