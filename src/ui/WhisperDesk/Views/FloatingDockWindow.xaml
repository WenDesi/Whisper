<Window x:Class="WhisperDesk.Views.FloatingDockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mdxaml="clr-namespace:MdXaml;assembly=MdXaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <Window.Resources>
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PulseRing" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="1" To="1.35" Duration="0:0:0.9"/>
            <DoubleAnimation Storyboard.TargetName="PulseRing" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="1" To="1.35" Duration="0:0:0.9"/>
            <DoubleAnimation Storyboard.TargetName="PulseRing" Storyboard.TargetProperty="Opacity"
                             From="0.6" To="0" Duration="0:0:0.9"/>
        </Storyboard>

        <Storyboard x:Key="SpinnerAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="SpinnerRotation" Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:1.2"/>
        </Storyboard>
    </Window.Resources>

    <Grid Margin="12">
        <!-- Pulse ring (Listening state) -->
        <Ellipse x:Name="PulseRing" Width="56" Height="56"
                 Stroke="#FF5252" StrokeThickness="2" Opacity="0"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Circular dock button -->
        <Border x:Name="DockButton" Width="56" Height="56" CornerRadius="28"
                Cursor="Hand"
                MouseLeftButtonDown="OnButtonMouseLeftButtonDown"
                MouseMove="OnButtonMouseMove"
                MouseLeftButtonUp="OnButtonMouseLeftButtonUp"
                MouseRightButtonUp="OnRightClick">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#6A4DDB" Offset="0"/>
                    <GradientStop Color="#3A2D7A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush x:Name="RingBrush" Color="#B388FF" Opacity="0.95"/>
            </Border.BorderBrush>
            <Border.BorderThickness>2</Border.BorderThickness>
            <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.5" Color="Black"/>
            </Border.Effect>

            <Grid>
                <!-- Mic glyph (vector, always white & visible) -->
                <Path x:Name="MicIcon" Stretch="Uniform" Width="22" Height="22"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Fill="White"
                      Data="M12 14a3 3 0 0 0 3-3V5a3 3 0 0 0-6 0v6a3 3 0 0 0 3 3z M19 11a1 1 0 1 0-2 0 5 5 0 0 1-10 0 1 1 0 1 0-2 0 7 7 0 0 0 6 6.92V21h-2a1 1 0 1 0 0 2h6a1 1 0 1 0 0-2h-2v-3.08A7 7 0 0 0 19 11z"/>

                <!-- Spinner overlay (Transcribing/Cleaning) -->
                <Canvas x:Name="SpinnerPanel" Width="44" Height="44" Visibility="Collapsed">
                    <Canvas.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotation" CenterX="22" CenterY="22"/>
                    </Canvas.RenderTransform>
                    <Ellipse Width="5" Height="5" Canvas.Left="19.5" Canvas.Top="0" Fill="#448AFF"/>
                    <Ellipse Width="4" Height="4" Canvas.Left="34" Canvas.Top="6" Fill="#448AFF" Opacity="0.7"/>
                    <Ellipse Width="3.5" Height="3.5" Canvas.Left="38" Canvas.Top="20" Fill="#448AFF" Opacity="0.4"/>
                    <Ellipse Width="3" Height="3" Canvas.Left="32" Canvas.Top="34" Fill="#448AFF" Opacity="0.2"/>
                </Canvas>
            </Grid>
        </Border>

        <!-- Speech bubble popup -->
        <Popup x:Name="BubblePopup"
               PlacementTarget="{Binding ElementName=DockButton}"
               Placement="Custom"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               StaysOpen="True">
            <Border x:Name="BubbleBorder"
                    CornerRadius="12" Padding="14,10,10,10"
                    Width="480" MinWidth="240" MaxWidth="900"
                    MouseEnter="OnBubbleMouseEnter"
                    MouseLeave="OnBubbleMouseLeave">
                <Border.Background>
                    <SolidColorBrush Color="#1A1A2E" Opacity="0.96"/>
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#7C4DFF" Opacity="0.5"/>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.45" Color="Black"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <mdxaml:MarkdownScrollViewer Grid.Column="0"
                                                 x:Name="BubbleViewer"
                                                 MaxHeight="360"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Disabled"
                                                 Background="Transparent"
                                                 Foreground="#E8E8E8"
                                                 FontFamily="Segoe UI"
                                                 FontSize="13"
                                                 Padding="0"
                                                 MarkdownStyleName="Sasabune"/>

                    <Button Grid.Column="1" Content="✕"
                            Width="22" Height="22" Margin="10,0,0,0"
                            Padding="0" Background="Transparent"
                            BorderThickness="0" Foreground="#888"
                            Cursor="Hand" FontSize="12"
                            VerticalAlignment="Top"
                            Click="OnCloseBubbleClick"/>

                    <!-- Resize grip (bottom-right corner) -->
                    <Thumb x:Name="ResizeThumb"
                           Grid.Column="1"
                           Width="14" Height="14"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Margin="0,0,-6,-4"
                           Cursor="SizeNWSE"
                           DragDelta="OnResizeThumbDragDelta"
                           ToolTip="拖动调整大小">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Path Stroke="#888" StrokeThickness="1.2" SnapsToDevicePixels="True"
                                      Data="M 2 12 L 12 2 M 5 12 L 12 5 M 8 12 L 12 8"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</Window>
